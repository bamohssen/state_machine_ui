<?php

/**
 * @file
 * Procedural hooks for state_machine_ui.
 */

/**
 * Implements hook_workflow_groups_alter().
 */
function state_machine_ui_workflow_groups_alter(array &$workflow_groups): void {
  \Drupal::service(\Drupal\state_machine_ui\Hook\StateMachineUiHooks::class)
    ->workflowGroupsAlter($workflow_groups);
}

/**
 * Implements hook_workflows_alter().
 */
function state_machine_ui_workflows_alter(array &$workflows): void {
  \Drupal::service(\Drupal\state_machine_ui\Hook\StateMachineUiHooks::class)
    ->workflowsAlter($workflows);
}

/**
 * Implements hook_form_alter().
 */
function state_machine_ui_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state, string $form_id): void {
  \Drupal::service(\Drupal\state_machine_ui\Hook\FormHooks::class)
    ->formAlter($form, $form_state, $form_id);
}

/**
 * Implements hook_requirements().
 */
function state_machine_ui_requirements(string $phase): array {
  return \Drupal::service(\Drupal\state_machine_ui\Hook\StateMachineUiHooks::class)
    ->requirements($phase);
}
